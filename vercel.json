{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm docs:build",
  "outputDirectory": "doc_build",
  "installCommand": "pnpm install --frozen-lockfile",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
