{
  "name": "modernjs-typed-routes",
  "version": "0.0.0",
  "description": "Type-safe routes for Modern.js apps — generates TypeScript types from your file-based routes and ships typed Link, Navigate and useNavigate wrappers.",
  "keywords": [
    "modernjs",
    "modern.js",
    "typed-routes",
    "typesafe",
    "react-router",
    "codegen",
    "routes",
    "typescript"
  ],
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./plugin": {
      "import": {
        "types": "./dist/plugin/index.d.ts",
        "default": "./dist/plugin/index.js"
      },
      "require": {
        "types": "./dist/plugin/index.d.cts",
        "default": "./dist/plugin/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rslib",
    "check": "biome check --write",
    "dev": "rslib --watch",
    "docs:build": "rspress build",
    "docs:dev": "rspress dev",
    "docs:preview": "rspress preview",
    "format": "biome format --write",
    "test": "rstest",
    "test:watch": "rstest --watch",
    "lint:package": "publint && attw --pack ."
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@biomejs/biome": "2.4.15",
    "@microsoft/api-extractor": "^7.58.9",
    "@modern-js/app-tools": "3.6.0",
    "@rslib/core": "^0.23.2",
    "@rspress/core": "^2.0.17",
    "@rstest/adapter-rslib": "^0.10.6",
    "@rstest/core": "^0.10.6",
    "@types/node": "^24.13.2",
    "publint": "^0.3.21",
    "typescript": "^6.0.3"
  },
  "private": true,
  "module": "./dist/index.js",
  "sideEffects": false,
  "peerDependencies": {
    "@modern-js/app-tools": "^3.6.0",
    "@modern-js/runtime": "^3.6.0",
    "react": ">=17"
  },
  "peerDependenciesMeta": {
    "@modern-js/app-tools": {
      "optional": true
    }
  },
  "typesVersions": {
    "*": {
      "plugin": [
        "./dist/plugin/index.d.ts"
      ]
    }
  }
}
