{
  "name": "modernjs-typed-routes",
  "version": "0.1.2",
  "description": "Type-safe routes for Modern.js apps — generates TypeScript types from your file-based routes and ships typed Link, Navigate and useNavigate wrappers.",
  "keywords": [
    "modernjs",
    "modern.js",
    "typed-routes",
    "typesafe",
    "react-router",
    "codegen",
    "routes",
    "typescript"
  ],
  "license": "MIT",
  "author": "Giancarlos Isasi <giancarlos.isasi@gmail.com>",
  "homepage": "https://modernjs-typed-routes.gio-labs.com",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/giancarlosisasi/modernjs-typed-routes.git"
  },
  "bugs": {
    "url": "https://github.com/giancarlosisasi/modernjs-typed-routes/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./plugin": {
      "import": {
        "types": "./dist/plugin/index.d.ts",
        "default": "./dist/plugin/index.js"
      },
      "require": {
        "types": "./dist/plugin/index.d.cts",
        "default": "./dist/plugin/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rslib",
    "check": "biome check --write",
    "dev": "rslib --watch",
    "docs:build": "rspress build",
    "docs:dev": "rspress dev",
    "docs:preview": "rspress preview",
    "format": "biome format --write",
    "test": "rstest && pnpm run test:types && pnpm run check:docs-snippets && pnpm run check:playground",
    "check:docs-snippets": "tsc -p examples/playground/docs-snippets",
    "check:playground": "pnpm --dir examples/playground exec tsc -p . --noEmit",
    "test:watch": "rstest --watch",
    "lint:package": "publint && attw --pack .",
    "release": "pnpm build && changeset publish",
    "test:e2e": "rstest --config rstest.e2e.config.ts",
    "test:e2e:update": "node scripts/update-playground-snapshot.mjs",
    "test:types": "pnpm run test:types:src && pnpm run test:types:dist",
    "test:types:src": "tsc -p tests/types/single && tsc -p tests/types/multi && tsc -p tests/types/empty",
    "test:types:dist": "pnpm run build && tsc -p tests/types/single/tsconfig.dist.json && tsc -p tests/types/multi/tsconfig.dist.json && tsc -p tests/types/empty/tsconfig.dist.json && tsc -p tests/types/single/tsconfig.dcts.json"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@biomejs/biome": "2.4.15",
    "@changesets/cli": "^2.31.0",
    "@microsoft/api-extractor": "^7.58.9",
    "@modern-js/app-tools": "3.6.0",
    "@modern-js/runtime": "^3.6.0",
    "@rsbuild/plugin-react": "^2.1.0",
    "@rslib/core": "^0.23.2",
    "@rspress/core": "^2.0.17",
    "@rstest/adapter-rslib": "^0.10.6",
    "@rstest/core": "^0.10.6",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "expect-type": "^1.4.0",
    "jsdom": "^29.1.1",
    "publint": "^0.3.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3"
  },
  "module": "./dist/index.js",
  "sideEffects": false,
  "peerDependencies": {
    "@modern-js/app-tools": "^3.6.0",
    "@modern-js/runtime": "^3.6.0",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "@modern-js/app-tools": {
      "optional": true
    }
  },
  "typesVersions": {
    "*": {
      "plugin": [
        "./dist/plugin/index.d.ts"
      ]
    }
  }
}
